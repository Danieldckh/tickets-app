# ProAgri Tickets Admin — environment variables
# Copy to .env and fill in real values before running locally.

PORT=3000

# Base URL of the Agri360 CRM (used for SSO redirect + API proxy target).
AGRI360_API_BASE=https://agri360.proagrihub.com

# Public base URL of Agri360 (exposed to the SPA for building attachment URLs).
# Usually the same as AGRI360_API_BASE.
AGRI360_PUBLIC_BASE=https://agri360.proagrihub.com

# Public URL of THIS app (used to build the SSO redirect-back URL).
PUBLIC_URL=https://tickets.proagrihub.com

# Shared secret between Agri360 and this app — must match TICKET_ADMIN_KEY in Agri360.
TICKET_ADMIN_KEY=

# Secret used to verify SSO tokens issued by Agri360 — must match SSO_SHARED_SECRET in Agri360.
SSO_SHARED_SECRET=

# Secret used to sign the session cookie issued by this app (random, private to this app).
SESSION_SECRET=
